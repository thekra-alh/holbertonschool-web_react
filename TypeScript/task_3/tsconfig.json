{
  "compilerOptions": {
    "target": "ES5",
    "module": "ESNext",
    "strict": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowJs": true,
    "lib": ["DOM", "ES2015"],
    "skipLibCheck": true
  },
  "include": ["js/**/*"]
}
